# ─────────────────────────────────────────────────────────────────────────────
# Mission Control — Environment Variables
# Copie para .env e preencha com valores reais.
# .env está no .gitignore — NUNCA commite o arquivo .env com valores reais.
# ─────────────────────────────────────────────────────────────────────────────

# Banco de dados (PostgreSQL)
# Formato: postgresql://USER:PASS@HOST:PORT/DB
DATABASE_URL=postgresql://evolution:SUA_SENHA_POSTGRES@postgres:5432/mission_control
DATABASE_SSL=false

# Auth JWT — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=gere-uma-chave-aleatoria-de-64-chars

# Senha inicial do admin (bootstrap automático no primeiro login)
ADMIN_PASSWORD=SUA_SENHA_ADMIN

# Sessão (horas)
SESSION_HOURS=24

# Mercado Livre — tokens multi-conta (caminho dentro do container)
ML_TOKENS_PATH=/opt/ml-data/tokens.json

# APIs externas
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Evolution API (WhatsApp) — usado pelo SRE check e envio de mensagens
# Valor: AUTHENTICATION_API_KEY do container evolution-api-h4pg-api-1
EVOLUTION_API_KEY=sua-evolution-api-key

# n8n — API key para SRE check de workflow ativo
# Gerar em: painel n8n > Settings > API > Create API Key
N8N_API_KEY=sua-n8n-api-key

# URL pública do Mission Control (sem trailing slash)
MC_URL=https://mc.wingx.app.br
