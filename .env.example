# ─────────────────────────────────────────────────────────────────────────────
# Mission Control — Environment Variables
# Copie para .env e preencha com valores reais.
# .env está no .gitignore — NUNCA commite o arquivo .env com valores reais.
#
# Em PRODUÇÃO: todos os valores vêm de GitHub Secrets → deploy.yml → .env na VPS.
# Para adicionar/alterar: GitHub Settings → Secrets and variables → Actions
#
# CRÍTICO = app não sobe sem este valor (deploy bloqueado no CI)
# OPCIONAL = feature degrada mas app funciona (warning no CI)
# ─────────────────────────────────────────────────────────────────────────────

# ── INFRA (deploy) ─── CRÍTICO ───────────────────────────────────────────────
# VPS_SSH_KEY   → GitHub Secret (não vai no .env local)
# VPS_HOST      → GitHub Secret (não vai no .env local)

# ── BANCO DE DADOS ─── CRÍTICO ───────────────────────────────────────────────
# Formato: postgresql://USER:PASS@HOST:PORT/DB
# Local: usar SSH tunnel (ssh -L 5433:localhost:5432 root@VPS) + porta 5433
DATABASE_URL=postgresql://evolution:SUA_SENHA_POSTGRES@postgres:5432/mission_control
DATABASE_SSL=false
# Pool separado para rotas paraguai/* que consultam o DB arbitragem.
# Role=evolution (dona das tabelas); mc_app não tem CREATE em arbitragem pós-C3.6.
# Sem esta var, pool faz fallback swap /mission_control→/arbitragem no DATABASE_URL (dev).
ARBITRAGEM_DATABASE_URL=postgresql://evolution:SUA_SENHA_POSTGRES@postgres:5432/arbitragem

# ── AUTH ─── CRÍTICO ─────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=gere-uma-chave-aleatoria-de-64-chars
# Senha inicial do admin (bootstrap automático no primeiro login se tabela users vazia)
ADMIN_PASSWORD=SUA_SENHA_ADMIN
SESSION_HOURS=24

# ── WORKER KEY ─── CRÍTICO ───────────────────────────────────────────────────
# Chave usada pelos workers/crons para autenticar em endpoints internos
# GitHub Secret: WORKER_KEY → env var: MC_WORKER_KEY
MC_WORKER_KEY=sua-worker-key-aqui

# ── CRIPTOGRAFIA ─── CRÍTICO ─────────────────────────────────────────────────
# AES-256 para CPF/telefone de clientes ML. Se mudar, dados criptografados ficam ilegíveis.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DB_ENCRYPTION_KEY=gere-uma-chave-aes-256-de-64-chars

# ── FILA DE IMPRESSÃO ─── CRÍTICO ────────────────────────────────────────────
# Chave de acesso ao dashboard público da fila (/fila?key=...)
QUEUE_KEY=sua-queue-key-aqui
# Chave do agente de impressão (WingX Agent)
PRINT_AGENT_KEY=sua-print-agent-key-aqui

# ── WHATSAPP / EVOLUTION API ─── OPCIONAL ────────────────────────────────────
# Sem estes: SRE alerts e mensagens WhatsApp não funcionam
# Valor de EVOLUTION_API_KEY: AUTHENTICATION_API_KEY do container evolution-api-h4pg-api-1
EVOLUTION_API_KEY=sua-evolution-api-key
# Número do grupo WhatsApp para alertas SRE (formato: 5511999999999@g.us)
SRE_WHATSAPP_GROUP=5511999999999@g.us

# ── N8N ─── OPCIONAL ─────────────────────────────────────────────────────────
# Sem este: SRE check de workflow ativo não funciona
# Gerar em: painel n8n > Settings > API > Create API Key
N8N_API_KEY=sua-n8n-api-key

# ── MELHOR ENVIO ─── OPCIONAL ────────────────────────────────────────────────
# Sem estes: geração de etiquetas ME não funciona
MELHOR_ENVIO_ENV=production
# CPF/CNPJ do remetente para etiquetas
ME_SENDER_DOCUMENT=00000000000
# Token de produção (obtido via OAuth em mc.wingx.app.br/connectors)
ME_PROD_TOKEN=
ME_PROD_CLIENT_SECRET=
# Token de sandbox (para testes)
ME_SANDBOX_TOKEN=
ME_SANDBOX_CLIENT_SECRET=

# ── APIS EXTERNAS ─── OPCIONAL ───────────────────────────────────────────────
# Sem estes: scraping de preços e cambio não funcionam
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GITHUB ─── OPCIONAL (apenas local — NÃO vai para produção) ───────────────
# PAT para o state_gate checar status do CI (actions:read + repo)
# Gerar em: https://github.com/settings/tokens → Fine-grained token
# NÃO colocar nos GitHub Secrets — é só para uso local do harness/state_gate
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GITHUB WEBHOOK ─── OPCIONAL ──────────────────────────────────────────────
# HMAC-SHA256 secret compartilhado com webhook em github.com/cganbit/mission-control/settings/hooks
# Sem este: POST /api/github/webhooks retorna 401 (fail-closed). Gera com:
#   openssl rand -hex 32
# GitHub Secret: MC_GITHUB_WEBHOOK_SECRET → env var: MC_GITHUB_WEBHOOK_SECRET
MC_GITHUB_WEBHOOK_SECRET=

# ── URLS ─────────────────────────────────────────────────────────────────────
MC_URL=https://mc.wingx.app.br
